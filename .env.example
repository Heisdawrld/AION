# AION — Environment Configuration
# Copy this to .env and fill in the values
# Minimum to get started: DATABASE_URL + at least one AI provider key

# ============================================================
# DATABASE (Required — local SQLite by default)
# ============================================================
DATABASE_URL="file:./dev.db"
# For Turso (edge SQLite):
# DATABASE_URL="libsql://your-db.turso.io"
# DATABASE_AUTH_TOKEN="your-turso-token"

# ============================================================
# API AUTHENTICATION
# ============================================================
AION_API_KEY="your-api-key-here"
NEXT_PUBLIC_AION_API_KEY="your-api-key-here"

# ============================================================
# AI PROVIDERS (At least ONE required — all are FREE tiers)
# Groq is the easiest to get started with: https://console.groq.com
# ============================================================

# --- Groq (fastest free option, recommend starting here) ---
# Get key: https://console.groq.com/keys
GROQ_API_KEY="gsk_..."
# Optional model overrides:
# GROQ_HEAVY_MODEL="llama-3.3-70b-versatile"
# GROQ_MEDIUM_MODEL="llama-3.3-70b-versatile"
# GROQ_LIGHT_MODEL="llama-3.1-8b-instant"
# GROQ_BASE_URL="https://api.groq.com/openai/v1"

# --- Google Gemini (free, 1500 req/day) ---
# Get key: https://aistudio.google.com/apikey
# GEMINI_API_KEY="AIza..."
# GEMINI_HEAVY_MODEL="gemini-2.0-flash"
# GEMINI_MEDIUM_MODEL="gemini-2.0-flash"
# GEMINI_LIGHT_MODEL="gemini-2.0-flash-lite"
# GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"

# --- Cerebras (ultra-fast inference) ---
# Get key: https://cloud.cerebras.ai/
# CEREBRAS_API_KEY="..."
# CEREBRAS_HEAVY_MODEL="llama-3.3-70b"
# CEREBRAS_MEDIUM_MODEL="llama-3.3-70b"
# CEREBRAS_LIGHT_MODEL="llama-3.1-8b"
# CEREBRAS_BASE_URL="https://api.cerebras.ai/v1"

# --- Sambanova (free 70B model) ---
# Get key: https://cloud.sambanova.ai/
# SAMBANOVA_API_KEY="..."
# SAMBANOVA_HEAVY_MODEL="Meta-Llama-3.3-70B-Instruct"
# SAMBANOVA_MEDIUM_MODEL="Meta-Llama-3.3-70B-Instruct"
# SAMBANOVA_LIGHT_MODEL="Meta-Llama-3.1-8B-Instruct"
# SAMBANOVA_BASE_URL="https://api.sambanova.ai/v1"

# --- OpenRouter (access to many models) ---
# Get key: https://openrouter.ai/keys
# OPENROUTER_API_KEY="sk-or-..."
# OPENROUTER_HEAVY_MODEL="google/gemini-2.0-flash-001"
# OPENROUTER_MEDIUM_MODEL="meta-llama/llama-3.3-70b-instruct"
# OPENROUTER_LIGHT_MODEL="meta-llama/llama-3.1-8b-instruct"
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# --- Legacy: OpenAI-compatible (only used if no other keys set) ---
# OPENAI_API_KEY="sk-..."
# OPENAI_BASE_URL="https://api.openai.com/v1"
# OPENAI_MODEL="gpt-4o-mini"
# OPENAI_HEAVY_API_KEY="sk-..."
# OPENAI_LIGHT_API_KEY="sk-..."

# ============================================================
# ZAI SDK (legacy fallback — only if no OpenAI-compatible keys)
# ============================================================
# ZAI_BASE_URL="https://api.z.ai/v1"
# ZAI_API_KEY="..."
# ZAI_CHAT_ID="aion-...-id"
# ZAI_TOKEN="..."
# ZAI_USER_ID="aion-server"

# ============================================================
# DEPLOYMENT
# ============================================================
# VERCEL_TOKEN="..."  # For auto-deploy to Vercel from the DevOps agent
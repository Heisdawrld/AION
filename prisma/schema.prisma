// AION — Autonomous Intelligent Orchestration Network
// Database Schema (Turso/libSQL — SQLite-compatible, edge-ready)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id            String   @id @default(cuid())
  name          String
  description   String
  status        String   @default("planning") // planning | building | testing | deploying | live | failed
  prd           String?  // JSON string of PRD
  executionPlan String?  // JSON string of ExecutionPlan
  liveUrl       String?
  githubRepo    String?
  totalCycles   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tasks        Task[]
  files        ProjectFile[]
  bugs         Bug[]
  testResults  TestResult[]
  agentLogs    AgentLog[]
  deployments  Deployment[]
  conversations ConversationMessage[]
  costEntries  AICostEntry[]
  workspaces   RepoWorkspace[]
  runs         ExecutionRun[]
  approvals    ApprovalRequest[]
  artifacts    ExecutionArtifact[]
}

model Task {
  id          String   @id @default(cuid())
  projectId   String
  description String
  assignedTo  String   // cto | frontend | backend | qa | devops | business
  status      String   @default("pending") // pending | in_progress | review | done | failed
  priority    String   @default("medium")  // critical | high | medium | low
  phase       String   @default("build")   // discover | plan | build | test | ship
  retryCount  Int      @default(0)
  maxRetries  Int      @default(3)
  output      String?  // JSON string of task output
  feedback    String?  // Feedback from QA or Lead
  dependsOn   String?  // JSON array of task IDs this depends on
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectFile {
  id        String   @id @default(cuid())
  projectId String
  path      String
  content   String
  createdBy String   // Agent role that created this file
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Bug {
  id          String    @id @default(cuid())
  projectId   String
  description String
  filePath    String?
  severity    String    @default("medium") // critical | high | medium | low
  status      String    @default("open")   // open | assigned | fixing | resolved
  reportedBy  String    // Agent role
  assignedTo  String?   // Agent role
  fixTaskId   String?   // Task ID created to fix this bug
  resolvedAt  DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model TestResult {
  id        String   @id @default(cuid())
  projectId String
  testType  String   // build | typecheck | api | url
  passed    Boolean
  details   String?  // Error details if failed
  ranAt     DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AgentLog {
  id         String   @id @default(cuid())
  projectId  String
  agentRole  String   // cto | frontend | backend | qa | devops | business
  action     String   // What the agent did
  task       String?  // Task description
  input      String?  // JSON string of input
  output     String?  // JSON string of output
  duration   Int?     // milliseconds
  confidence Float?   // 0-1
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Deployment {
  id         String    @id @default(cuid())
  projectId  String
  platform   String    @default("render")
  status     String    @default("pending") // pending | building | deployed | failed
  url        String?
  githubRepo String?
  errors     String?   // Error details if failed
  deployedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ConversationMessage {
  id          String   @id @default(cuid())
  projectId   String
  role        String   // user | cto | system
  content     String
  agentRole   String?  // Which agent this message is from
  metadata    String?  // JSON string for extra data
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ============================================================
// AGENT MEMORY SYSTEM
// ============================================================

model AgentMemoryEntry {
  id          String    @id @default(cuid())
  agentRole   String
  category    String    // task_pattern | error_resolution | project_context | general
  pattern     String    // The pattern, key information, or error signature
  resolution  String?   // How it was resolved or the approach taken
  confidence  Float     @default(0.5)
  projectId   String?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime? // null = permanent
}

model AgentTaskPattern {
  id          String    @id @default(cuid())
  agentRole   String
  taskType    String
  approach    String
  outcome     String    // success | failure | partial
  confidence  Float     @default(0.5)
  frequency   Int       @default(1)
  projectId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  expiresAt   DateTime?
}

model AgentErrorResolution {
  id            String   @id @default(cuid())
  agentRole     String
  errorPattern  String
  resolution    String
  workedCount   Int      @default(0)
  failedCount   Int      @default(0)
  projectId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AgentProjectContext {
  id          String   @id @default(cuid())
  projectId   String
  key         String
  value       String
  updatedBy   String   // agent role
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, key])
}

model AICostEntry {
  id            String   @id @default(cuid())
  projectId     String?
  agentRole     String
  model         String
  inputTokens   Int
  outputTokens  Int
  duration      Int      // milliseconds
  estimatedCost Int      // cost in cents
  taskSnippet   String?
  createdAt     DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model BudgetConfig {
  id             String   @id @default(cuid())
  projectId      String?  @unique // null = global budget
  dailyLimit     Int      // cents
  monthlyLimit   Int      // cents
  alertThreshold Float    @default(0.8)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ============================================================
// EXECUTION CONTROL PLANE
// ============================================================

model RepoWorkspace {
  id            String    @id @default(cuid())
  projectId     String
  name          String
  slug          String
  repoUrl       String?
  repoProvider  String?
  defaultBranch String?   @default("main")
  currentBranch String?   @default("main")
  rootPath      String?
  status        String    @default("inactive") // inactive | ready | syncing | running | error
  isPrimary     Boolean   @default(false)
  lastSyncedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project   Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runs      ExecutionRun[]
  approvals ApprovalRequest[]
  artifacts ExecutionArtifact[]

  @@unique([projectId, slug])
}

model ExecutionRun {
  id               String    @id @default(cuid())
  projectId        String
  workspaceId      String?
  agentRole        String?
  kind             String    // command | git | browser | scrape | build | test | deploy | research
  status           String    @default("queued") // queued | awaiting_approval | running | blocked | completed | failed | cancelled
  summary          String
  command          String?
  requestedBy      String?
  approvalRequired Boolean   @default(false)
  startedAt        DateTime?
  completedAt      DateTime?
  output           String?
  error            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  project   Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace RepoWorkspace?      @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  approvals ApprovalRequest[]
  artifacts ExecutionArtifact[]
}

model ApprovalRequest {
  id             String    @id @default(cuid())
  projectId      String
  workspaceId    String?
  runId          String?
  type           String    // git_push | deploy | credentials | destructive_command | secret_change | migration
  riskLevel      String    @default("medium") // low | medium | high | critical
  status         String    @default("pending") // pending | approved | rejected | expired
  summary        String
  commandPreview String?
  diffSummary    String?
  requestedBy    String?
  decidedBy      String?
  decisionReason String?
  decidedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace RepoWorkspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  run       ExecutionRun?  @relation(fields: [runId], references: [id], onDelete: SetNull)
}

model ExecutionArtifact {
  id           String    @id @default(cuid())
  projectId    String
  workspaceId  String?
  runId        String?
  kind         String    // log | diff | screenshot | html | json | test_report | browser_trace
  title        String
  path         String?
  contentType  String?
  content      String?
  metadata     String?
  sizeBytes    Int?
  createdAt    DateTime  @default(now())

  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace RepoWorkspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  run       ExecutionRun?  @relation(fields: [runId], references: [id], onDelete: SetNull)
}
